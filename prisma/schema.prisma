// Prisma schema — Mini Multi-Tenant Property Listing Platform
// Tenancy model: a Property Owner IS a tenant. Every Property/Image/Favorite
// is scoped to a tenant via ownerId/tenantId in a single shared schema
// (row-level scoping). Schema-per-tenant is the documented scale-up path.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  OWNER
  USER
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         Role       @default(USER)
  // For an OWNER this equals their own id (they ARE the tenant).
  tenantId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  properties Property[] @relation("OwnerProperties")
  favorites  Favorite[]

  @@index([role])
  @@index([tenantId])
}

model Property {
  id              String         @id @default(cuid())
  // tenantId == owner's id. Never trusted from client; derived from JWT.
  tenantId        String
  owner           User           @relation("OwnerProperties", fields: [tenantId], references: [id])
  title           String
  description     String
  location        String
  price           Int // stored in whole currency units; must be > 0 to publish
  status          PropertyStatus @default(DRAFT)
  disabledByAdmin Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  publishedAt     DateTime?
  deletedAt       DateTime?

  images    PropertyImage[]
  favorites Favorite[]

  @@index([tenantId])
  @@index([status])
  @@index([location])
  @@index([price])
  @@index([status, disabledByAdmin, deletedAt])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  mimeType   String
  sizeBytes  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([propertyId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}
