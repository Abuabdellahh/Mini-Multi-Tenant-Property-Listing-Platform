# ---- Database (Neon Postgres) ----
# Pooled connection used at runtime by the app.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct (unpooled) connection used by Prisma migrate / db push.
DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# ---- Auth ----
# Secret used to sign JWTs. Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-secret"

# ---- Optional: seed passwords override ----
# SEED_PASSWORD="Password123!"
